{
  "name": "image2prompt-monorepo",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "dev:extension": "cd apps/extension && bun run dev",
    "dev:web": "cd apps/web && bun run dev",
    "build:extension": "cd apps/extension && bun run build",
    "build:web": "cd apps/web && bun run build"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^6.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "packageManager": "bun@1.3.1"
}
